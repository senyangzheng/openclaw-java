<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration loaded only in CLI mode (see bin/openclaw-java).
  Silences every framework logger so that the shell output contains ONLY
  the text the subcommand itself writes via System.out.

  Kept as a plain logback.xml (not logback-spring.xml) on purpose, so that it
  applies BEFORE Spring Environment is ready — otherwise the early
  status / startup / validator messages would slip through.
-->
<configuration>

  <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

  <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
    <target>System.err</target>
    <encoder>
      <pattern>%-5level %logger{0} - %msg%n</pattern>
    </encoder>
  </appender>

  <!--
    Only ERROR is surfaced, and it is routed to stderr so the CLI
    can still pipe its stdout cleanly even when something blows up.
  -->
  <root level="ERROR">
    <appender-ref ref="STDERR"/>
  </root>

  <logger name="com.openclaw" level="ERROR" additivity="false">
    <appender-ref ref="STDERR"/>
  </logger>

</configuration>
